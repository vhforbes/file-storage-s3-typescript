{
  "name": "Bun & TypeScript + Go + Postgres (sidecar)",
  "dockerComposeFile": ["docker-compose.yaml"],
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "service": "app",
  "remoteUser": "root",
  "features": {
    "ghcr.io/devcontainers/features/go:1": {
      "version": "1.22",
      "installTools": true
    }
  },
  "postStartCommand": "go install github.com/bootdotdev/bootdev@latest",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "ms-vscode.vscode-typescript-next",
        "esbenp.prettier-vscode",
        "yoavbls.pretty-ts-errors"
      ],
      "settings": {
        "go.useLanguageServer": true
      }
    }
  },
  "forwardPorts": [8091],
  "postCreateCommand": "go version && bun -v"
}
